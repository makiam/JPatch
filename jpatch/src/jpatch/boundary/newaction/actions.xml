<actions>
	<buttongroup type="standard" name="layout"/>
	<buttongroup type="standard" name="tool"/>
	
	<action name="viewport layout" model="combo">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportLayoutAction" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_1.png"/>
		<property key="ShortDescription" value="Viewport layout" />
	</action>
	
	<action name="single view" model="default">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportSingleAction" />
		<property key="ShortDescription" value="Single"/>
		<property key="Mnemonic" value="s" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_single.png"/>
	</action>
	
	<action name="vertically split view" model="default">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportSplitVAction" />
		<property key="ShortDescription" value="Split vertically"/>
		<property key="Mnemonic" value="v" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_split_v.png"/>
	</action>
	
	<action name="horizontally split view" model="default">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportSplitHAction" />
		<property key="ShortDescription" value="Split horizontally"/>
		<property key="Mnemonic" value="h" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_split_h.png"/>
	</action>
	
	<action name="quad view" model="default">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportQuadAction" />
		<property key="ShortDescription" value="Quad"/>
		<property key="Mnemonic" value="q" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_quad.png"/>
	</action>
	
	<action name="viewport 1" model="radio" group="layout">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportS1Action" />
		<property key="ShortDescription" value="Viewport 1"/>
		<property key="Accelerator" value="pressed 1" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_1.png"/>
	</action>
	
	<action name="viewport 2" model="radio" group="layout">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportS2Action" />
		<property key="ShortDescription" value="Viewport 2"/>
		<property key="Accelerator" value="pressed 2" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_2.png"/>
	</action>
	
	<action name="viewport 3" model="radio" group="layout">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportS3Action" />
		<property key="ShortDescription" value="Viewport 3"/>
		<property key="Accelerator" value="pressed 3" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_3.png"/>
	</action>
	
	<action name="viewport 4" model="radio" group="layout">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportS4Action" />
		<property key="ShortDescription" value="Viewport 4"/>
		<property key="Accelerator" value="pressed 4" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_4.png"/>
	</action>
	
	<action name="viewport 12" model="radio" group="layout">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportH12Action" />
		<property key="ShortDescription" value="Viewports 1 and 2"/>
		<property key="Accelerator" value="pressed 5" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_12.png"/>
	</action>
	
	<action name="viewport 34" model="radio" group="layout">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportH34Action" />
		<property key="ShortDescription" value="Viewports 3 and 4"/>
		<property key="Accelerator" value="pressed 6" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_34.png"/>
	</action>
	
	<action name="viewport 13" model="radio" group="layout">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportV13Action" />
		<property key="ShortDescription" value="Viewports 1 and 3"/>
		<property key="Accelerator" value="pressed 7" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_13.png"/>
	</action>
	
	<action name="viewport 24" model="radio" group="layout">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportV24Action" />
		<property key="ShortDescription" value="Viewports 2 and 4"/>
		<property key="Accelerator" value="pressed 8" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_24.png"/>
	</action>
	
	<action name="viewport 1234" model="radio" group="layout">
		<instantiate class="jpatch.boundary.newaction.ChangeViewActions" method="createViewportQuadAction" />
		<property key="ShortDescription" value="Viewports 1, 2, 3 and 4"/>
		<property key="Accelerator" value="pressed 9" />
		<property key="Icon" value="jpatch/images/icons_16x16/viewport_1234.png"/>
	</action>
	
	<action name="move view" model="locking radio" group="tool">
		<instantiate class="jpatch.boundary.newaction.ChangeToolActions" method="createMoveViewAction" />
		<property key="ShortDescription" value="Move view" />
		<property key="Mnemonic" value="m" />
		<property key="Icon" value="jpatch/images/move.png" />
	</action>
	
	<action name="rotate view" model="locking radio" group="tool">
		<instantiate class="jpatch.boundary.newaction.ChangeToolActions" method="createRotateViewAction" />
		<property key="ShortDescription" value="Rotate view" />
		<property key="Mnemonic" value="r" />
		<property key="Icon" value="jpatch/images/rotate.png" />
	</action>
	
	<action name="zoom view" model="locking radio" group="tool">
		<instantiate class="jpatch.boundary.newaction.ChangeToolActions" method="createZoomViewAction" />
		<property key="ShortDescription" value="Zoom view" />
		<property key="Mnemonic" value="r" />
		<property key="Icon" value="jpatch/images/zoom.png" />
	</action>
	
	<action name="translate tool" model="locking radio" group="tool">
		<instantiate class="jpatch.boundary.newaction.ChangeToolActions" method="createTranslateAction" />
		<property key="ShortDescription" value="Translate tool" />
		<property key="Accelerator" value="pressed Q" />
		<property key="Mnemonic" value="t" />
		<property key="Icon" value="jpatch/images/default.png" />
	</action>
	
	<action name="add curve segment" model="locking radio" group="tool">
		<instantiate class="jpatch.boundary.newaction.ChangeToolActions" method="createAddCurveAction" />
		<property key="ShortDescription" value="Add curve segment" />
		<property key="Accelerator" value="pressed A" />
		<property key="Mnemonic" value="a" />
		<property key="Icon" value="jpatch/images/add.png" />
	</action>
	
	<action name="new project" model="default">
		<instantiate class="jpatch.boundary.newaction.ProjectActions" method="createNewProjectAction" />
		<property key="ShortDescription" value="New project" />
	</action>
	
	<action name="open project" model="default">
		<instantiate class="jpatch.boundary.newaction.ProjectActions" method="createOpenProjectAction" />
		<property key="ShortDescription" value="Open project" />
	</action>
	
	<action name="close project" model="default">
		<instantiate class="jpatch.boundary.newaction.ProjectActions" method="createCloseProjectAction" />
		<property key="ShortDescription" value="Close project" />
	</action>
	
	<action name="delete project" model="default">
		<instantiate class="jpatch.boundary.newaction.ProjectActions" method="createDeleteProjectAction" />
		<property key="ShortDescription" value="Delete project" />
	</action>
	
</actions>