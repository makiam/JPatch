		<property key="Icon" value="jpatch/images/icons_16x16/viewport_1234.png"/>
	</action>
	
	<action name="add curve segment" model="default">
		<instantiate class="jpatch.boundary.newaction.EditModelActions" method="createAddCurveAction" />
		<property key="ShortDescription" value="Add curve segment(s)" />
		<property key="Accelerator" value="pressed A" />
		<property key="Mnemonic" value="a" />
		<property key="Icon" value="jpatch/images/add.png" />
	</action>
